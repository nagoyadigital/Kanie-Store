{
  "name": "ServiceOrder",
  "type": "object",
  "properties": {
    "service_number": {
      "type": "string"
    },
    "customer_name": {
      "type": "string"
    },
    "customer_phone": {
      "type": "string"
    },
    "device_brand": {
      "type": "string"
    },
    "device_model": {
      "type": "string"
    },
    "imei": {
      "type": "string"
    },
    "complaint": {
      "type": "string"
    },
    "diagnosis": {
      "type": "string"
    },
    "technician": {
      "type": "string"
    },
    "estimated_cost": {
      "type": "number"
    },
    "final_cost": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "Waiting",
        "In Progress",
        "Completed",
        "Picked Up"
      ],
      "default": "Waiting"
    },
    "received_date": {
      "type": "string",
      "format": "date"
    },
    "completed_date": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "customer_name",
    "device_brand",
    "device_model",
    "complaint"
  ]
}