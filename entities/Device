    },
    "face_id": {
      "type": "string",
      "enum": [
        "Working",
        "Not Working",
        "N/A"
      ],
      "default": "N/A"
    },
    "touch_id": {
      "type": "string",
      "enum": [
        "Working",
        "Not Working",
        "N/A"
      ],
      "default": "N/A"
    },
    "display_type": {
      "type": "string",
      "enum": [
        "Original",
        "Replaced",
        "OEM"
      ],
      "default": "Original"
